<Window x:Class="WellSoft.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Обработчик данных скважин" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Загрузить CSV" Command="{Binding LoadFileCommand}" Padding="10,5" Margin="0,0,5,0"/>
            <Button Content="Экспорт в JSON" Command="{Binding ExportJsonCommand}" Padding="10,5"/>
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="10,0,0,0"/>
        </StackPanel>

        <GroupBox Grid.Row="1" Header="Сводка по скважинам" Margin="0,0,0,5">
            <DataGrid ItemsSource="{Binding Summaries}" 
                      SelectedItem="{Binding SelectedWellSummary, Mode=TwoWay}"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="WellId" Binding="{Binding WellId}" Width="80"/>
                    <DataGridTextColumn Header="X" Binding="{Binding X, StringFormat=F2}" Width="80"/>
                    <DataGridTextColumn Header="Y" Binding="{Binding Y, StringFormat=F2}" Width="80"/>
                    <DataGridTextColumn Header="Общая глубина" Binding="{Binding TotalDepth, StringFormat=F2}" Width="100"/>
                    <DataGridTextColumn Header="Кол-во интервалов" Binding="{Binding IntervalCount}" Width="120"/>
                    <DataGridTextColumn Header="Ср. пористость по толщине" Binding="{Binding AvgPorosity, StringFormat=F3}" Width="170"/>
                    <DataGridTextColumn Header="Самая распр. порода по сумм. толщине" Binding="{Binding MostCommonRock}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Интервалы выбранной скважины" Margin="0,0,0,5">
            <DataGrid ItemsSource="{Binding SelectedWellIntervals}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="DepthFrom" Binding="{Binding DepthFrom, StringFormat=F2}" Width="100"/>
                    <DataGridTextColumn Header="DepthTo" Binding="{Binding DepthTo, StringFormat=F2}" Width="100"/>
                    <DataGridTextColumn Header="Rock" Binding="{Binding Rock}" Width="150"/>
                    <DataGridTextColumn Header="Porosity" Binding="{Binding Porosity, StringFormat=F3}" Width="100"/>
                    <DataGridTextColumn Header="Line" Binding="{Binding LineNumber}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Row="3" Header="Ошибки валидации">
            <DataGrid ItemsSource="{Binding Errors}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Строка" Binding="{Binding LineNumber}" Width="60"/>
                    <DataGridTextColumn Header="WellId" Binding="{Binding WellId}" Width="80"/>
                    <DataGridTextColumn Header="Сообщение" Binding="{Binding Message}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</Window>
